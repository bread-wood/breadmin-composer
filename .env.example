# brimstone environment variables
# Copy this file to .env and fill in the required values.

# Required credentials
ANTHROPIC_API_KEY=your-anthropic-api-key-here
BRIMSTONE_GH_TOKEN=your-github-token-here   # GitHub token for yeast-bot (needs repo + workflow scopes)

# Optional — defaults shown
# BRIMSTONE_MODEL=claude-opus-4-6
# BRIMSTONE_MAX_BUDGET_USD=5.00           # USD budget cap per session
# BRIMSTONE_MAX_CONCURRENCY=5             # max concurrent sub-agents
# BRIMSTONE_AGENT_TIMEOUT_MINUTES=30.0    # minutes before a sub-agent is killed
# BRIMSTONE_SUBSCRIPTION_TIER=pro         # pro | max | max20x
# BRIMSTONE_DEFAULT_BRANCH=main           # expected default branch name
# BRIMSTONE_LOG_DIR=~/.brimstone/logs     # session logs and cost ledger
# BRIMSTONE_CHECKPOINT_DIR=~/.brimstone/checkpoints
# BRIMSTONE_API_KEY_HELPER=               # path to script that prints the API key on stdout
